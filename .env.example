# Copy this file to .env and fill in your own values: cp .env.example .env
# Never commit your real .env. Keep your currency API key secret, since it
# ships with usage limits and can be abused if exposed.
#
# The exact variable names depend on your stack and providers. Rename these to
# match your framework's conventions (for example, NEXT_PUBLIC_* in Next.js).

# --- Currency conversion API (required for both full-stack and frontend-only) ---
# Free keys: ExchangeRate-API, Open Exchange Rates, Fixer.io, FreeCurrencyAPI.
CURRENCY_API_KEY=
CURRENCY_API_BASE_URL=

# --- Database (full-stack path only) ---
# Connection string for Supabase, Neon, PlanetScale, Turso, or similar.
DATABASE_URL=

# --- Authentication (full-stack path only) ---
# Secrets for your auth provider: Supabase Auth, Clerk, Auth0, NextAuth, etc.
AUTH_SECRET=
# Base URL of the app: http://localhost:3000 in dev, your live URL in production.
AUTH_URL=
